# Copy to .env and fill in. Jira Cloud REST auth (Basic: email + API token).
# Create a token at https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Optional: restrict to your own tickets (assignee = currentUser()). true|false
JIRA_MY_TICKETS_ONLY=false

# Server port (the web dev server proxies /api here)
PORT=3001

# Optional override for the config file path (defaults to ./hangar.config.json)
# CONFIG_PATH=/absolute/path/to/hangar.config.json

# Demo mode: serve a fictional board + seeded sessions. Fully self-contained — no Jira and
# no hangar.config.json needed (your real config/.env are ignored). Great for a first look
# or for screenshots. Just set this and run `npm run dev`.
# HANGAR_DEMO=1
