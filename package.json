{
  "name": "hangar",
  "version": "0.7.0",
  "private": true,
  "license": "MIT",
  "description": "A mouse-driven board that turns Jira tickets into Claude Code agent sessions.",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix web install",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "typecheck": "npm --prefix server run typecheck && npm --prefix web run typecheck",
    "test": "npm --prefix server test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch:server": "npm --prefix server run watch",
    "watch:web": "npm --prefix web run watch",
    "watch": "concurrently -n ts-server,ts-web -c blue,magenta \"npm:watch:server\" \"npm:watch:web\"",
    "prepare": "husky || true",
    "screenshots": "node scripts/screenshots.mjs",
    "validate": "node scripts/validate-screenshots.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "playwright": "^1.50.0",
    "typescript-eslint": "^8.61.1"
  }
}
