{
  "agentsDir": "~/.claude/agents",
  "boards": [
    {
      "key": "DEMO",
      "name": "My Project",
      "statuses": ["To Do", "In Progress", "In Review", "Done"],
      "repoPaths": ["~/path/to/your/repo"],
      "agents": ["code-reviewer", "debugger"]
    }
  ],
  "aiWorkflow": {
    "projects": [
      {
        "id": "example-project",
        "name": "Dynamic Core",
        "repoPath": "~/dev/dynamiccore",
        "columns": ["Planning", "Design", "Implementation", "Review", "Delivery", "Complete"],
        "createdAt": 0
      }
    ]
  },
  "bypassPermissions": false,
  "isolateRuns": true,
  "terminal": "osascript -e 'tell application \"Terminal\" to do script \"cd \\\"{{dir}}\\\" && {{command}}\"' -e 'tell application \"Terminal\" to activate'"
}
